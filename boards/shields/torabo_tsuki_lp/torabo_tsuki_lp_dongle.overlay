    physical_layout_l: physical_layout_2 {
        compatible = "zmk,physical-layout";
        display-name = "L Layout";
        transform = <&size_l_transform>;
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0   60       0     0     0>
